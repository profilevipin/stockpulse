        {
            "id": "check-exchange-result",
            "name": "Check Exchange Result",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1560,
                200
            ],
            "parameters": {
                "jsCode": "const resp = $input.first().json;\nconst ctx = $(\"Compute Checksum\").first().json;\n\nif (resp.data && resp.data.access_token) {\n  return [{ json: {\n    success: true,\n    access_token: resp.data.access_token,\n    user_id: ctx.user_id,\n    chat_id: ctx.chat_id,\n    telegram_user_id: ctx.telegram_user_id\n  }}];\n}\n\nconst errorMsg = resp.message || resp.error_type || 'Token exchange failed. Please login again.';\nreturn [{ json: {\n  success: false,\n  error: errorMsg,\n  chat_id: ctx.chat_id\n}}];"
            }
