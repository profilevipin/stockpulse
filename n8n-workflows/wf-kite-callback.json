        },
        {
            "id": "compute-checksum-cb",
            "name": "Compute Checksum",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1120,
                200
            ],
            "parameters": {
                "jsCode": "// Pure JS SHA256 - no modules needed\nfunction sha256(ascii) {\n  function rr(v, a) { return (v >>> a) | (v << (32 - a)); }\n  var mp = Math.pow, mw = 4294967296, r = \"\", w = [], abl = ascii.length * 8;\n  var h = [], k = [], pc = 0, ic = {};\n  for (var c = 2; pc < 64; c++) {\n    if (!ic[c]) {\n      for (var i = 0; i < 313; i += c) ic[i] = c;\n      h[pc] = (mp(c, .5) * mw) | 0;\n      k[pc++] = (mp(c, 1/3) * mw) | 0;\n    }\n  }\n  ascii += \"\u0080\";\n  while (ascii.length % 64 - 56) ascii += \"\u0000\";\n  for (i = 0; i < ascii.length; i++) {\n    var j = ascii.charCodeAt(i);\n    w[i >> 2] |= j << ((3 - i) % 4) * 8;\n  }\n  w[w.length] = (abl / mw) | 0;\n  w[w.length] = abl;\n  for (j = 0; j < w.length;) {\n    var ww = w.slice(j, j += 16), oh = h;\n    h = h.slice(0, 8);\n    for (i = 0; i < 64; i++) {\n      var w15 = ww[i-15], w2 = ww[i-2], a = h[0], e = h[4];\n      var t1 = h[7] + (rr(e,6) ^ rr(e,11) ^ rr(e,25)) + ((e & h[5]) ^ (~e & h[6])) + k[i]\n        + (ww[i] = i < 16 ? ww[i] : (ww[i-16] + (rr(w15,7) ^ rr(w15,18) ^ (w15>>>3)) + ww[i-7] + (rr(w2,17) ^ rr(w2,19) ^ (w2>>>10))) | 0);\n      var t2 = (rr(a,2) ^ rr(a,13) ^ rr(a,22)) + ((a & h[1]) ^ (a & h[2]) ^ (h[1] & h[2]));\n      h = [(t1 + t2) | 0].concat(h);\n      h[4] = (h[4] + t1) | 0;\n    }\n    for (i = 0; i < 8; i++) h[i] = (h[i] + oh[i]) | 0;\n  }\n  for (i = 0; i < 8; i++)\n    for (j = 3; j + 1; j--)\n      r += ((h[i] >> (j * 8) & 255) < 16 ? \"0\" : \"\") + (h[i] >> (j * 8) & 255).toString(16);\n  return r;\n}\n\nconst creds = $(\"Fetch Kite Credentials\").first().json;\nconst token = $(\"Check Callback Params\").first().json.request_token;\nconst apiKey = creds.api_key || \"\";\nconst apiSecret = creds.api_secret || \"\";\nconst checksum = sha256(apiKey + token + apiSecret);\n\nreturn [{ json: {\n  api_key: apiKey,\n  request_token: token,\n  checksum: checksum,\n  user_id: creds.user_id,\n  telegram_user_id: creds.telegram_user_id,\n  chat_id: creds.chat_id\n}}];"
            }
        },
