# StockPulse v3.2 — Environment Variables
# Copy to .env and fill in your values

# Domain & SSL
DOMAIN=stockpulse.yourdomain.com

# n8n Auth
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_STRONG_PASSWORD
N8N_ENCRYPTION_KEY=GENERATE_32_CHAR_RANDOM_STRING

# PostgreSQL
POSTGRES_DB=stockpulse
POSTGRES_USER=stockpulse
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIjKlmNoPqRsTuVwXyZ

# Kite Connect — User 1 only (from developers.kite.trade)
KITE_API_KEY_USER1=your_kite_api_key
KITE_API_SECRET_USER1=your_kite_api_secret

# Claude API (from console.anthropic.com)
CLAUDE_API_KEY=sk-ant-api03-XXXXXXXX

# Free APIs
NEWSAPI_KEY=your_newsapi_key
FINNHUB_KEY=your_finnhub_key

# Encryption key for Kite tokens at rest
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=GENERATE_64_HEX_CHARS

# Bootstrap user IDs (DB is source of truth after setup)
ADMIN_TELEGRAM_USER_ID=123456789
USER2_TELEGRAM_USER_ID=987654321
